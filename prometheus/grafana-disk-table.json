{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "filterable": false,
            "inspect": false
          },
          "mappings": [
            { "options": { "0": { "color": "red", "text": "失败" } }, "type": "value" },
            { "options": { "1": { "color": "green", "text": "正常" } }, "type": "value" },
            { "options": { "2": { "color": "yellow", "text": "未知" } }, "type": "value" },
            { "options": { "-1": { "color": "red", "text": "不支持" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 },
              { "color": "yellow", "value": 2 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "健康状态" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "mode": "basic", "type": "color-background" } },
              { "id": "custom.width", "value": 100 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "温度(°C)" },
            "properties": [
              { "id": "unit", "value": "none" },
              { "id": "thresholds", "value": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "yellow", "value": 40 },
                  { "color": "orange", "value": 50 },
                  { "color": "red", "value": 60 }
                ]
              }},
              { "id": "custom.width", "value": 100 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "寿命消耗(%)" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "max", "value": 100 },
              { "id": "min", "value": 0 },
              { "id": "thresholds", "value": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "yellow", "value": 50 },
                  { "color": "orange", "value": 80 },
                  { "color": "red", "value": 95 }
                ]
              }},
              { "id": "custom.cellOptions", "value": { "mode": "gradient", "type": "color-background" } },
              { "id": "custom.width", "value": 120 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "通电时间(小时)" },
            "properties": [
              { "id": "unit", "value": "none" },
              { "id": "custom.width", "value": 130 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "重映射扇区" },
            "properties": [
              { "id": "unit", "value": "none" },
              { "id": "custom.width", "value": 110 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "SMART" },
            "properties": [
              { "id": "mappings", "value": [
                { "options": { "0": { "color": "red", "text": "不支持" } }, "type": "value" },
                { "options": { "1": { "color": "green", "text": "支持" } }, "type": "value" }
              ]},
              { "id": "custom.cellOptions", "value": { "mode": "basic", "type": "color-background" } },
              { "id": "custom.width", "value": 80 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "服务器" },
            "properties": [{ "id": "custom.width", "value": 180 }]
          },
          {
            "matcher": { "id": "byName", "options": "设备" },
            "properties": [{ "id": "custom.width", "value": 90 }]
          },
          {
            "matcher": { "id": "byName", "options": "型号" },
            "properties": [{ "id": "custom.width", "value": 220 }]
          },
          {
            "matcher": { "id": "byName", "options": "类型" },
            "properties": [{ "id": "custom.width", "value": 70 }]
          },
          {
            "matcher": { "id": "byName", "options": "序列号" },
            "properties": [{ "id": "custom.width", "value": 180 }]
          },
          {
            "matcher": { "id": "byName", "options": "挂载点" },
            "properties": [{ "id": "custom.width", "value": 150 }]
          }
        ]
      },
      "gridPos": { "h": 20, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": true, "fields": "", "reducer": ["sum"], "show": true },
        "showHeader": true,
        "sortBy": [
          { "desc": true, "displayName": "寿命消耗(%)" }
        ]
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "smart_health_status",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "smart_temperature_celsius",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "smart_percentage_used",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "smart_power_on_hours",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "D"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "smart_reallocated_sectors",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "E"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "smart_smart_available",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "F"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "smart_remaining_life_hours > 0",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "G"
        }
      ],
      "title": "磁盘健康状态一览表",
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true
            },
            "indexByName": {
              "hostname": 0,
              "device": 1,
              "model": 2,
              "type": 3,
              "serial": 4,
              "mountpoints": 5,
              "Value #A": 6,
              "Value #B": 7,
              "Value #C": 8,
              "Value #D": 9,
              "Value #E": 10,
              "Value #F": 11,
              "Value #G": 12
            },
            "renameByName": {
              "Value #A": "健康状态",
              "Value #B": "温度(°C)",
              "Value #C": "寿命消耗(%)",
              "Value #D": "通电时间(小时)",
              "Value #E": "重映射扇区",
              "Value #F": "SMART",
              "Value #G": "剩余寿命(小时)",
              "device": "设备",
              "hostname": "服务器",
              "model": "型号",
              "serial": "序列号",
              "type": "类型",
              "mountpoints": "挂载点"
            }
          }
        }
      ],
      "type": "table"
    }
  ],
  "refresh": "5m",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["disk", "health", "smart", "lifecycle"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "label": "数据源",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "queryValue": "",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      },
      {
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(smart_health_status, hostname)",
        "hide": 0,
        "includeAll": true,
        "label": "服务器",
        "multi": true,
        "name": "hostname",
        "options": [],
        "query": { "query": "label_values(smart_health_status, hostname)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(smart_health_status{hostname=~\"$hostname\"}, type)",
        "hide": 0,
        "includeAll": true,
        "label": "磁盘类型",
        "multi": true,
        "name": "type",
        "options": [],
        "query": { "query": "label_values(smart_health_status{hostname=~\"$hostname\"}, type)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "磁盘健康统计表",
  "uid": "disk-health-table",
  "version": 1,
  "weekStart": ""
}
