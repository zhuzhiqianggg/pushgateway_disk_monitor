        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "count(smart_health_status == 1)",
          "legendFormat": "正常",
          "refId": "A"
        },
        {
          "expr": "count(smart_health_status == 0)",
          "legendFormat": "失败",
          "refId": "B"
        },
        {
          "expr": "count(smart_health_status == 2)",
          "legendFormat": "未知",
          "refId": "C"
        }
      ],
