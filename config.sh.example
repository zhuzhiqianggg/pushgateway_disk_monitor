#!/bin/bash
# ============================================================
# 磁盘健康监控 - 配置文件（模板）
# 使用方法: cp config.sh.example config.sh，然后修改
# ============================================================

# ==================== 服务器列表 ====================
# 每行一个 IP 或 hostname
SERVERS=(
    "192.168.10.150"
    "192.168.10.151"
    "192.168.10.152"
    "192.168.10.155"
    "192.168.10.198"
)

# ==================== SSH 认证 ====================
# SSH 登录用户（留空则运行时交互式输入）
SSH_USER="root"

# SSH 密码（留空则运行时交互式输入；有 SSH 密钥时优先使用密钥认证）
SSH_PASS=""

# ==================== 部署参数 ====================
PUSHGATEWAY_URL="http://121.36.241.152:9091"
PUSH_INTERVAL="3600"
REMOTE_INSTALL_DIR="/opt/monitor/disk_monitor"
SSH_PORT=22
SSH_CONNECT_TIMEOUT=15
